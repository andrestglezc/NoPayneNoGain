{
  "expo": {
    "name": "No Payne No Gain",
    "slug": "no-payne-no-gain",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "nopayne",
    "splash": {
      "backgroundColor": "#070A0D",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nopayne.nogain",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.nopayne.nogain",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#070A0D"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e070032d-3d5c-4743-9ecf-078dbed2f39e"
      }
    },
    "owner": "andres.t.glez.c"
  }
}
